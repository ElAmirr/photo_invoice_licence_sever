# PostgreSQL connection string from Render (use Internal URL when deployed on Render)
DATABASE_URL=postgresql://shootix_db2_user:YOUR_PASSWORD@dpg-xxxx.oregon-postgres.render.com/shootix_db2

# Secret token to protect the admin key-generation endpoint
ADMIN_SECRET=change_me_to_a_very_long_random_secret

# Port (Render sets this automatically; default 3000 for local dev)
PORT=3000
